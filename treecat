в”Ӯ   в”Ӯ 			if delta == 0
в”Ӯ   в”Ӯ 			then 0
в”Ӯ   в”Ӯ 			else if maxC == r'
в”Ӯ   в”Ӯ 			then ((g' - b') / delta)
