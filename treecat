│ │   │   │ 	hex = s: lib.removePrefix "#" s;
│ │   │   │ 	c.a = vars.theme.colors.accent;
│ │   │   │ 	c.b = vars.theme.colors.base;
│ │   │   │ in {
│ │   │   │ 	console = {
