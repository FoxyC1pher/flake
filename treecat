│ │   │   │ # ── Console colors ────────────────────────────────────────────────────────────
│ │   │   │ # Replaces stylix.targets.console. Sets the 16 VT color slots from the raw
│ │   │   │ # palette. NixOS console.colors takes hex strings WITHOUT the leading #.
│ │   │   │ {
│ │   │   │ 	lib,
