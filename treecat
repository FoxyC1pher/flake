в”Ӯ   в”Ӯ 			map (name: {
в”Ӯ   в”Ӯ 					inherit name;
в”Ӯ   в”Ӯ 					hex = attrs.${name};
в”Ӯ   в”Ӯ 					diff = hueDiff (rgbToHsl (hexToRgb attrs.${name})).h targetHue;
в”Ӯ   в”Ӯ 				})
в”Ӯ   в”Ӯ 			items;
