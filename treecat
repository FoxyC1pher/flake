в”Ӯ   в”Ӯ 	hexToRgb = hex: {
в”Ӯ   в”Ӯ 		r = hex2Dec (builtins.substring 1 2 hex);
в”Ӯ   в”Ӯ 		g = hex2Dec (builtins.substring 3 2 hex);
в”Ӯ   в”Ӯ 		b = hex2Dec (builtins.substring 5 2 hex);
в”Ӯ   в”Ӯ 	};
в”Ӯ   в”Ӯ
в”Ӯ   в”Ӯ 	rgbToHsl = {
в”Ӯ   в”Ӯ 		r,
в”Ӯ   в”Ӯ 		g,
в”Ӯ   в”Ӯ 		b,
в”Ӯ   в”Ӯ 	}: let
в”Ӯ   в”Ӯ 		r' = r / 255.0;
в”Ӯ   в”Ӯ 		g' = g / 255.0;
в”Ӯ   в”Ӯ 		b' = b / 255.0;
