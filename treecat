в”Ӯ   в”Ӯ 	# HEX conversion
в”Ӯ   в”Ӯ 	hexCharVal = ch:
в”Ӯ   в”Ӯ 		{
в”Ӯ   в”Ӯ 			"0" = 0;
в”Ӯ   в”Ӯ 			"1" = 1;
в”Ӯ   в”Ӯ 			"2" = 2;
в”Ӯ   в”Ӯ 			"3" = 3;
в”Ӯ   в”Ӯ 			"4" = 4;
в”Ӯ   в”Ӯ 			"5" = 5;
в”Ӯ   в”Ӯ 			"6" = 6;
в”Ӯ   в”Ӯ 			"7" = 7;
в”Ӯ   в”Ӯ 			"8" = 8;
в”Ӯ   в”Ӯ 			"9" = 9;
в”Ӯ   в”Ӯ 			"a" = 10;
в”Ӯ   в”Ӯ 			"b" = 11;
в”Ӯ   в”Ӯ 			"c" = 12;
в”Ӯ   в”Ӯ 			"d" = 13;
в”Ӯ   в”Ӯ 			"e" = 14;
в”Ӯ   в”Ӯ 			"f" = 15;
в”Ӯ   в”Ӯ 			"A" = 10;
в”Ӯ   в”Ӯ 			"B" = 11;
в”Ӯ   в”Ӯ 			"C" = 12;
в”Ӯ   в”Ӯ 			"D" = 13;
в”Ӯ   в”Ӯ 			"E" = 14;
в”Ӯ   в”Ӯ 			"F" = 15;
в”Ӯ   в”Ӯ 		}.${
в”Ӯ   в”Ӯ 			ch
в”Ӯ   в”Ӯ 		} or (throw "invalid hex digit ${ch}");
