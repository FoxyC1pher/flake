│   │ 			map (name: {
│   │ 					inherit name;
│   │ 					hex = attrs.${name};
│   │ 					diff = hueDiff (rgbToHsl (hexToRgb attrs.${name})).h targetHue;
│   │ 				})
│   │ 			items;
│   │ 		best =
│   │ 			builtins.foldl' (a: b:
│   │ 					if b.diff < a.diff
│   │ 					then b
│   │ 					else a) (builtins.head withDiff) (builtins.tail withDiff);
