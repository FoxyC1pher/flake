│   │ 	# Пользовательские min/max/abs
│   │ 	maxVal = a: b:
│   │ 		if a > b
│   │ 		then a
│   │ 		else b;
│   │ 	minVal = a: b:
│   │ 		if a < b
│   │ 		then a
│   │ 		else b;
│   │ 	absVal = x:
│   │ 		if x < 0
